# -------------------------------------------------------
# Application
# -------------------------------------------------------
APP_NAME="ERV V2"
APP_ENV=local
APP_KEY=                          # php artisan key:generate
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -------------------------------------------------------
# Logging  (use stderr on Vercel)
# -------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# -------------------------------------------------------
# Database — local: SQLite  |  production: libsql (Turso)
# -------------------------------------------------------
DB_CONNECTION=sqlite
# DB_DATABASE=/absolute/path/or/leave-empty-for-default

# Turso / libSQL HTTP (production — set these in Vercel dashboard)
# DB_CONNECTION=libsql
# DB_DATABASE=libsql://<database>.turso.io
# DB_AUTH_TOKEN=<turso-auth-token>
#
# If you use the Vercel Turso integration, these names are also supported:
# TURSO_DATABASE_URL=libsql://<database>.turso.io
# TURSO_DATABASE_TURSO_AUTH_TOKEN=<turso-auth-token>

# -------------------------------------------------------
# Session
# -------------------------------------------------------
SESSION_DRIVER=database       # use cookie on Vercel (serverless)
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -------------------------------------------------------
# Cache / Queue
# -------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database           # use array on Vercel (serverless)
CACHE_PREFIX=

# -------------------------------------------------------
# Mail
# -------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -------------------------------------------------------
# Vite
# -------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
